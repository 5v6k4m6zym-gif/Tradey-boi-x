modules = ["nodejs-24", "python-3.12"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Tradey Boi X Dashboard"

[[workflows.workflow]]
name = "Tradey Boi X Dashboard"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd tradey-boi-x && streamlit run dashboard.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5050
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081
